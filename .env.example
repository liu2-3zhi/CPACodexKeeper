# CPA management API base URL / CPA 管理 API 地址
CPA_ENDPOINT=https://your-cpa-endpoint

# CPA management token / bearer credential / CPA 管理 token
CPA_TOKEN=your-management-token

# Optional HTTP/HTTPS proxy, for example: http://127.0.0.1:7890
# 可选 HTTP/HTTPS 代理，例如：http://127.0.0.1:7890
CPA_PROXY=

# Main full-scan daemon interval in seconds / 主巡检守护轮询间隔（秒）
CPA_INTERVAL=1800

# Log inspection loop interval in seconds / 日志巡检轮询间隔（秒）
# <= 0 disables log inspection; > 0 enables it and controls how often the loop runs
# 小于等于 0 表示禁用日志巡检；大于 0 表示启用，并控制日志巡检循环频率
CPA_FILL_INTERVAL=10

# Disable threshold percentage / 禁用阈值百分比
# The token will be disabled only when the checked quota reaches this value
# 只有当检查到的限额达到该值时才会禁用 token
CPA_QUOTA_THRESHOLD=100

# Fallback recheck delay in seconds when threshold-reaching quota windows expose no reset_at
# 达到禁用阈值但对应 quota 窗口没有 reset_at 时的回查延迟（秒）
CPA_QUOTA_RESET_NONE_RECHECK_SECONDS=18000

# Minimum delay between accounts during the main full scan / 主巡检两个账号之间的最小等待秒数
# Main full scan is sequential; this pacing does not affect log inspection or tracked rechecks
# 主巡检按账号串行执行；该节流不影响日志巡检和 tracked 自动复查
CPA_FULL_SCAN_MIN_INTERVAL_SECONDS=10

# Maximum delay between accounts during the main full scan / 主巡检两个账号之间的最大等待秒数
CPA_FULL_SCAN_MAX_INTERVAL_SECONDS=60

# Timeout when waiting for disabled_accounts.json lock / 等待 disabled_accounts.json 锁的超时时间（秒）
CPA_DISABLED_STATE_LOCK_TIMEOUT_SECONDS=10

# Retry interval when waiting for disabled_accounts.json lock / 等待 disabled_accounts.json 锁时的重试间隔（秒）
CPA_DISABLED_STATE_LOCK_RETRY_INTERVAL_SECONDS=0.2

# Delay before re-checking whether a just-enabled account is really enabled / 启用后再次确认账号状态前的等待时间（秒）
CPA_ENABLE_VERIFY_DELAY_SECONDS=5

# Maximum attempts for enable -> wait -> verify in maintainer auto-enable flow / 自动重新启用时“启用 -> 等待 -> 复查”的最大尝试次数
CPA_ENABLE_VERIFY_MAX_ATTEMPTS=3

# Refresh threshold in days / 刷新阈值（天）
# Disabled tokens with remaining lifetime below this value can be refreshed
# 剩余有效期低于该值的已禁用 token 会进入刷新判断
CPA_EXPIRY_THRESHOLD_DAYS=3

# Whether automatic refresh is enabled / 是否启用自动刷新
# When enabled, keeper refreshes only disabled tokens; enabled tokens are left to CPA
# 开启后 keeper 只刷新已禁用 token；启用状态 token 交给 CPA 处理
# Default is true, but keeper still refreshes only disabled tokens
# 默认开启，但 keeper 仍只刷新已禁用 token
CPA_ENABLE_REFRESH=true

# Whether daemon mode force-refreshes expiring tokens / 守护模式是否强制刷新临近过期 token
# When true, daemon-mode full inspections may temporarily disable enabled tokens, refresh them, then restore their original disabled/enabled state
# 开启后，守护模式全量巡检可对临近过期 token 执行强制刷新：必要时先临时禁用、刷新上传，再恢复原始禁用/启用状态
# This setting is ignored by --once; one-shot mode requires --once --force-refresh explicitly
# 该配置会被 --once 忽略；单次执行必须显式传入 --once --force-refresh 才会强制刷新
CPA_FORCE_REFRESH_ON_EXPIRY=false

# Whether auth-files may be deleted / 是否允许删除账号文件
# When false, main-flow delete actions are converted into disable actions instead
# 关闭后，主巡检中的删除动作会改为禁用动作
CPA_ALLOW_DELETE=true

# Timeout for CPA API requests in seconds / CPA API 请求超时（秒）
CPA_HTTP_TIMEOUT=30

# Timeout for OpenAI usage requests in seconds / OpenAI usage 请求超时（秒）
CPA_USAGE_TIMEOUT=15

# Retry count for transient network/server failures / 临时网络或服务端错误重试次数
CPA_MAX_RETRIES=2

# Maximum total size of archived log zip files in MB / 日志归档 zip 文件总大小上限（MB）
# Current run logs are written to ./logs/<start-time>.txt, and previous txt logs are archived into ./logs/archive on startup
# 当前运行日志会写入 ./logs/<启动时间>.txt，程序启动时会把之前的 txt 日志压缩归档到 ./logs/archive
CPA_LOG_ARCHIVE_MAX_SIZE_MB=500
